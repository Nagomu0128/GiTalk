{
  "mcpServers": {
    "gcloud": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "gcloud-mcp", "--project", "gitalk-01100128"],
      "env": {}
    },
    "gcs": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@google-cloud/storage-mcp", "--project", "gitalk-01100128"],
      "env": {}
    },
    "gsql": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@google-cloud/sql-mcp", "--project", "gitalk-01100128"],
      "env": {}
    },
    "firebase": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "firebase-tools@latest", "experimental:mcp"],
      "env": {}
    },
    "impeccable": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@anthropic-ai/impeccable-mcp"],
      "env": {}
    }
  }
}
